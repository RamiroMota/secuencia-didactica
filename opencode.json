{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "docfork": {
      "enabled": true,
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "docfork"
      ]
    },
    "puppeteer": {
      "enabled": true,
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    }
  }
}
